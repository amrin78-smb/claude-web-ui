{
  "name": "claude-web-ui",
  "version": "2.0.0",
  "private": true,
  "description": "Local web app that runs Claude Code in your browser",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently -n server,web -c yellow,cyan \"node server/index.js\" \"vite\"",
    "dev:server": "node server/index.js",
    "dev:web": "vite",
    "build": "vite build",
    "start": "node server/index.js",
    "check": "svelte-check --tsconfig ./web/tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@lydell/node-pty": "^1.2.0-beta.12",
    "express": "^5.2.1",
    "pptxgenjs": "^4.0.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@tsconfig/svelte": "^5.0.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "concurrently": "^9.1.0",
    "svelte": "^5.15.0",
    "svelte-check": "^4.1.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.10"
  }
}
